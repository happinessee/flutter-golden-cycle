/// Sets the golden render viewport. Call at the top of each `testWidgets` body
/// before `tester.pumpWidget(...)`.
Future<void> useGoldenViewport(WidgetTester tester) async {
  await tester.binding.setSurfaceSize(_kGoldenViewport);
  tester.view.devicePixelRatio = 1.0;
  tester.view.physicalSize = _kGoldenViewport * tester.view.devicePixelRatio;
  addTearDown(() {
    tester.binding.setSurfaceSize(null);
    tester.view.resetDevicePixelRatio();
    tester.view.resetPhysicalSize();
  });
}

/// Minimal MaterialApp host for golden renders. Wraps [child] in a sized
