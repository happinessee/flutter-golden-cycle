    debugShowCheckedModeBanner: false,
    theme: ThemeData(
      useMaterial3: true,
      fontFamily: _kFontFamily,
      colorScheme: ColorScheme.fromSeed(seedColor: const Color(0xFF4F46E5)),
    ),
    home: Scaffold(
      body: Center(
        child: SizedBox(width: width, child: child),
      ),
    ),
  );
}
