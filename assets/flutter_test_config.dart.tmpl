// Generated by flutter-golden-cycle-init. Controls golden diff tolerance
// across operating systems (Skia text/shadow AA differs between macOS /
// Linux / Windows).
//
// Place at <uiPackage>/test/flutter_test_config.dart — flutter_test picks it
// up automatically; no import needed.

import 'dart:async';
import 'dart:io';
import 'dart:typed_data';
import 'dart:ui' as ui;

import 'package:flutter_test/flutter_test.dart';
import 'package:path/path.dart' as p;

/// Pixel diff ratio (0.0 = strict, 0.02 = 2% — absorbs typical Skia AA drift).
/// Raising this hides real regressions; lowering it produces flaky cross-OS
/// failures. Per-platform goldens are the right escalation, not raising this.
const double _kMaxGoldenDiffRatio = {{goldenTolerance}};

Future<void> testExecutable(FutureOr<void> Function() testMain) async {
  goldenFileComparator = _ToleratedFileComparator(
    Uri.parse('${Directory.current.uri}test/'),
    _kMaxGoldenDiffRatio,
  );
  await testMain();
}

class _ToleratedFileComparator extends LocalFileComparator {
  _ToleratedFileComparator(Uri testBase, this._tolerance) : super(testBase);

  final double _tolerance;

  @override
  Future<bool> compare(Uint8List imageBytes, Uri golden) async {
    final result = await GoldenFileComparator.compareLists(
      imageBytes,
      await getGoldenBytes(golden),
    );
    if (result.passed) return true;

    if (result.diffPercent <= _tolerance) {
      // Within tolerance — log for visibility, still pass.
      // ignore: avoid_print
      print(
        '[golden] ${p.basename(golden.toString())} diff '
        '${(result.diffPercent * 100).toStringAsFixed(3)}% '
        '≤ ${(_tolerance * 100).toStringAsFixed(2)}% — accepted.',
      );
      return true;
    }

    final error = await generateFailureOutput(result, golden, basedir);
    throw FlutterError(error);
  }
}
